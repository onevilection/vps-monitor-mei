{
  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",

      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run:*)",
      "Bash(go fmt:*)",
      "Bash(gofmt:*)",
      "Bash(go mod tidy)",
      "Bash(go mod verify)",

      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet restore:*)"
    ],

    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(gh release:*)",
      "Bash(gh repo:*)",
      "Bash(go get:*)",
      "Bash(dotnet add package:*)",
      "Bash(dotnet publish:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "WebFetch"
    ],

    "deny": [
      "Read(./servers.json)",
      "Read(./state.json)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/id_ed25519*)",
      "Read(**/id_rsa*)",
      "Read(**/known_hosts)",
      "Write(./servers.json)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
