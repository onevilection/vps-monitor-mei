<Window x:Class="VpsWatcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VpsWatcher.App.ViewModels"
        Title="VPS監視-Mei (Phase 3a)"
        Width="380" Height="560"
        WindowStartupLocation="CenterScreen">
    <!-- Phase 3a: a normal window (default chrome, no transparency / Topmost / DragMove).
         Gadget appearance is Phase 3b. -->

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Metric label column -->
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Width" Value="68" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#444" />
        </Style>

        <!-- Metric value column (right-aligned numbers) -->
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Width" Value="92" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>

        <Style x:Key="PercentBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="14" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Margin" Value="6,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <!-- Empty state: shown when there is no server (config missing / connect init failed).
             StatusMessage is null when a server exists, so this collapses to nothing. -->
        <TextBlock Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" Foreground="#B00020"
                   VerticalAlignment="Top" />

        <!-- Single server panel (Phase 3a). The container stays for N-server (ItemsControl) in 3b. -->
        <ContentControl Content="{Binding Server}"
                        Visibility="{Binding HasServer, Converter={StaticResource BoolToVis}}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:ServerViewModel}">
                    <StackPanel>

                        <!-- Header: label + id -->
                        <TextBlock Text="{Binding Label}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding Id}" FontSize="11" Foreground="#888" Margin="0,0,0,6" />

                        <!-- Connection state line (color tracks state). -->
                        <TextBlock Text="{Binding StateText}" FontWeight="SemiBold" Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                            <Setter Property="Foreground" Value="#A06000" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Foreground" Value="#1B7F3B" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDisconnected}" Value="True">
                                            <Setter Property="Foreground" Value="#C25E00" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsHostKeyMismatch}" Value="True">
                                            <Setter Property="Foreground" Value="#B00020" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- TOP-PRIORITY WARNING: host-key mismatch = suspected MITM (design §6.1/§5.4.1).
                             Shown above the metrics, red, only when mismatched. Auto-reconnect is
                             stopped by the Core service; this banner persists until the user acts. -->
                        <Border Background="#B00020" CornerRadius="4" Padding="10" Margin="0,2,0,10"
                                Visibility="{Binding IsHostKeyMismatch, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="⚠️ ホスト鍵不一致（なりすまし疑い）"
                                           Foreground="White" FontWeight="Bold" FontSize="14"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="接続を停止しました。servers.json の knownHostKey を確認してください（要確認）。"
                                           Foreground="White" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- CPU -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CPU" Style="{StaticResource MetricLabel}" />
                            <ProgressBar Grid.Column="1" Style="{StaticResource PercentBar}" Value="{Binding CpuPct}" />
                            <TextBlock Grid.Column="2" Text="{Binding CpuText}" Style="{StaticResource MetricValue}" />
                        </Grid>

                        <!-- Memory -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="メモリ" Style="{StaticResource MetricLabel}" />
                            <ProgressBar Grid.Column="1" Style="{StaticResource PercentBar}" Value="{Binding MemPct}" />
                            <TextBlock Grid.Column="2" Text="{Binding MemText}" Style="{StaticResource MetricValue}" />
                        </Grid>

                        <!-- Swap -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Swap" Style="{StaticResource MetricLabel}" />
                            <ProgressBar Grid.Column="1" Style="{StaticResource PercentBar}" Value="{Binding SwapPct}" />
                            <TextBlock Grid.Column="2" Text="{Binding SwapText}" Style="{StaticResource MetricValue}" />
                        </Grid>

                        <!-- Disks (0..N mounts; never assume a fixed count, §4) -->
                        <TextBlock Text="ディスク" Foreground="#444" Margin="0,8,0,2" />
                        <ItemsControl ItemsSource="{Binding Disks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DiskGaugeViewModel}">
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Mount}" Style="{StaticResource MetricLabel}" />
                                        <ProgressBar Grid.Column="1" Style="{StaticResource PercentBar}" Value="{Binding UsedPct}" />
                                        <TextBlock Grid.Column="2" Text="{Binding UsedText}" Width="150"
                                                   TextAlignment="Right" VerticalAlignment="Center"
                                                   FontFamily="Consolas" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Network (rates have no fixed scale -> text only, no percentage bar) -->
                        <TextBlock Text="ネットワーク" Foreground="#444" Margin="0,10,0,2" />
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↓ rx" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Column="2" Text="{Binding RxText}" Style="{StaticResource MetricValue}" />
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="↑ tx" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Column="2" Text="{Binding TxText}" Style="{StaticResource MetricValue}" />
                        </Grid>

                        <!-- Load + uptime -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Load" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding LoadText}" FontFamily="Consolas" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="稼働" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding UptimeText}" FontFamily="Consolas" VerticalAlignment="Center" />
                        </Grid>

                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</Window>
